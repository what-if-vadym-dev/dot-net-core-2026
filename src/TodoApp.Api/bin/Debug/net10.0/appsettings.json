{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=todoapp.db"
  },
  "Jwt": {
    "Issuer": "TodoApp",
    "Audience": "TodoApp.Client",
    "SigningKey": "a-very-long-development-signing-key-change-me",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Oidc": {
    "Authority": "https://localhost:8443/realms/master",
    "ClientId": "todo-api",
    "ClientSecret": "todo-secret",
    "KeycloakAudience": "account"
  },
  "BasicAuth": {
    "User": "basic-user",
    "Password": "basic-pass"
  },
  "Cors": {
    "AllowedOrigins": [
      "*"
    ]
  },
  "ExternalApi": {
    "BaseUrl": "https://jsonplaceholder.typicode.com"
  },
  "LegacySoap": {
    "BaseUrl": "https://postman-echo.com"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Sinks.Elasticsearch",
      "Serilog.Sinks.Grafana.Loki"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "SeqUrl": "http://localhost:5341",
    "ElasticUrl": "http://localhost:9200",
    "LokiUrl": "http://localhost:3100"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
